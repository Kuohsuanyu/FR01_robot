<!-- KBOT_loco.mjcf — loco-mujoco 相容版本 -->
<!-- Joint 名稱對應 UnitreeH1，讓 LAFAN1 軌跡重定向自動映射腿部動作 -->
<!--
  Joint 名稱對應表：
    dof_right_hip_pitch_04  -> hip_flexion_r    (前後擺動)
    dof_right_hip_roll_03   -> hip_adduction_r  (側向收展)
    dof_right_hip_yaw_03    -> hip_rotation_r   (內外旋轉)
    dof_right_knee_04       -> knee_angle_r
    dof_right_ankle_02      -> ankle_angle_r
    左腿同理 (_r -> _l)
-->
<mujoco model="KBOT_loco">
  <default>
    <default class="robot">
      <default class="robstride_04">
        <joint armature="0.04" frictionloss="0.2" actuatorfrcrange="-120.0 120.0" />
        <motor ctrlrange="-120.0 120.0" />
      </default>
      <default class="robstride_02">
        <joint armature="0.0042" frictionloss="0.1" actuatorfrcrange="-17.0 17.0" />
        <motor ctrlrange="-17.0 17.0" />
      </default>
      <default class="robstride_03">
        <joint armature="0.02" frictionloss="0.2" actuatorfrcrange="-60.0 60.0" />
        <motor ctrlrange="-60.0 60.0" />
      </default>
      <default class="visual">
        <geom material="visualgeom" contype="0" conaffinity="0" group="2" />
      </default>
      <default class="collision">
        <geom material="collision_material" condim="3" contype="0" conaffinity="1" priority="1" group="1" solref="0.005 1" friction="0.64" />
      </default>
      <!-- mimic site 樣式（loco-mujoco 軌跡追蹤用） -->
      <default class="mimic">
        <site group="4" type="box" size="0.075 0.05 0.025" rgba="1.0 0.0 0.0 0.5"/>
      </default>
    </default>
    <mesh maxhullvert="64" />
  </default>

  <compiler angle="radian" />

  <asset>
    <material name="base_material" rgba="1 0 0 1" />
    <material name="Torso_Side_Right_material" rgba="0.7 0.7 0.7 1" />
    <material name="imu_material" rgba="0.615686 0.811765 0.929412 1" />
    <material name="default_material" rgba="0.7 0.7 0.7 1" />
    <material name="collision_material" rgba="1.0 0.28 0.1 0.9" />
    <material name="floor_material" rgba="0.8 0.8 0.8 1" />
    <material name="imu_marker_material" rgba="0 1 0.2 1" />
    <mesh name="imu.stl" file="meshes/legs/imu.stl" />
    <mesh name="KC_D_102R_R_Hip_Yoke_Drive.stl" file="meshes/legs/KC_D_102R_R_Hip_Yoke_Drive.stl" />
    <mesh name="RS03_4.stl" file="meshes/legs/RS03_4.stl" />
    <mesh name="KC_D_301R_R_Femur_Lower_Drive.stl" file="meshes/legs/KC_D_301R_R_Femur_Lower_Drive.stl" />
    <mesh name="KC_D_401R_R_Shin_Drive.stl" file="meshes/legs/KC_D_401R_R_Shin_Drive.stl" />
    <mesh name="KB_D_501R_R_LEG_FOOT.collision.stl" file="meshes/legs/KB_D_501R_R_LEG_FOOT.collision.stl" />
    <mesh name="KB_D_501R_R_LEG_FOOT.stl" file="meshes/legs/KB_D_501R_R_LEG_FOOT.stl" />
    <mesh name="KC_D_102L_L_Hip_Yoke_Drive.stl" file="meshes/legs/KC_D_102L_L_Hip_Yoke_Drive.stl" />
    <mesh name="RS03_5.stl" file="meshes/legs/RS03_5.stl" />
    <mesh name="KC_D_301L_L_Femur_Lower_Drive.stl" file="meshes/legs/KC_D_301L_L_Femur_Lower_Drive.stl" />
    <mesh name="KC_D_401L_L_Shin_Drive.stl" file="meshes/legs/KC_D_401L_L_Shin_Drive.stl" />
    <mesh name="KB_D_501L_L_LEG_FOOT.collision.stl" file="meshes/legs/KB_D_501L_L_LEG_FOOT.collision.stl" />
    <mesh name="KB_D_501L_L_LEG_FOOT.stl" file="meshes/legs/KB_D_501L_L_LEG_FOOT.stl" />
    <mesh name="torse_FR01" file="meshes/torso/torse_FR01.stl" />
    <mesh name="arm_right" file="meshes/arms/arm_right.stl" />
    <mesh name="arm_left"  file="meshes/arms/arm_left.stl" />
  </asset>

  <worldbody>
    <light directional="true" diffuse=".9 .9 .9" specular=".3 .3 .3" pos="0 0 5" dir="0 0 -1" />
    <geom name="floor" type="plane" size="0 0 0.5" pos="0 0 0"
          contype="1" conaffinity="1" condim="3" friction="0.8 0.005 0.0001"
          material="floor_material" />

    <!-- freejoint 改名為 root，與 H1 一致 -->
    <body name="pelvis" pos="0.00000000 0.00000000 1.01947904" quat="0.7071 0 0 0.7071" childclass="robot">
      <freejoint name="root" />

      <!-- mimic site: 骨盆（最重要的追蹤點） -->
      <site name="pelvis_mimic" class="mimic"/>

      <body name="upper_torso" pos="0 -0.095 0" quat="0.7071054825112363 0.0 0.0 0.7071080798594735">
        <inertial pos="0.093 0.003 -0.044" mass="9.640" diaginertia="0.154 0.116 0.096" />
        <geom name="upper_torso_mesh" type="mesh" mesh="torse_FR01" pos="-0.033 -0.098 -0.354"
              material="default_material" contype="0" conaffinity="0" group="2" />
        <!-- upper body mimic site -->
        <site name="upper_body_mimic" class="mimic" pos="0.05 0.0 0.3"/>

        <body name="imu" pos="0.093 0.0 -0.046" quat="0.7071067715114185 8.22589334037449e-07 0.7071067908607194 8.22589334037449e-07">
          <inertial pos="0.014737 -0.012000 0.003000" quat="1.0 0.0 0.0 0.0" mass="0.005700" diaginertia="1e-06 1e-06 2e-06" />
          <geom name="imu_visual" pos="0 0 0" quat="1.0 0.0 0.0 0.0" material="imu_material" type="mesh" mesh="imu.stl" class="visual" />
          <site name="imu_site" quat="1.0 0.0 0.0 0.0" pos="0.0 0.0 0.0" />
        </body>

        <!-- ===== 右腿 ===== -->
        <!-- Joint: hip_flexion_r (原 dof_right_hip_pitch_04) -->
        <body name="right_hip_yaw_link" pos="0.037469 0.000007 -0.284479" quat="0.5000001633974483 0.4999999999999733 0.49999983660255165 0.4999999999999733">
          <joint name="hip_flexion_r" type="hinge" ref="0.0" class="robstride_04" range="-2.216568 1.047198" axis="0 0 1" />
          <inertial pos="-0.005644 -0.004227 -0.038197" quat="1.0 0.0 0.0 0.0" mass="0.163" diaginertia="0.000270 0.000363 0.000390" />
          <geom name="KC_D_102R_R_Hip_Yoke_Drive_visual" pos="0 0 0" quat="1.0 0.0 0.0 0.0" material="Torso_Side_Right_material" type="mesh" mesh="KC_D_102R_R_Hip_Yoke_Drive.stl" class="visual" />
          <!-- mimic site: 右髖 -->
          <site name="right_hip_mimic" class="mimic" pos="0.05 0.0 0.0"/>

          <!-- Joint: hip_adduction_r (原 dof_right_hip_roll_03) -->
          <body name="right_hip_roll_link" pos="-0.028250 -0.030000 -0.071000" quat="-1.2247452309842457e-07 0.7071068967259713 1.22474483074382e-07 0.7071066656470838">
            <joint name="hip_adduction_r" type="hinge" ref="0.0" class="robstride_03" range="-2.268928 0.490" axis="0 0 -1" />
            <inertial pos="-0.000249 0.058017 0.025580" quat="1.0 0.0 0.0 0.0" mass="2.577" diaginertia="0.011097 0.003535 0.011585" />
            <geom name="RS03_4_visual" pos="0 0 0" quat="1.0 0.0 0.0 0.0" material="Torso_Side_Right_material" type="mesh" mesh="RS03_4.stl" class="visual" />

            <!-- Joint: hip_rotation_r (原 dof_right_hip_yaw_03) -->
            <body name="right_hip_pitch_link" pos="0 0.143000 0.024250" quat="0.7071068967259818 -0.7071066656470943 0.0 0.0">
              <joint name="hip_rotation_r" type="hinge" ref="0.0" class="robstride_03" range="-1.570796 1.570796" axis="0 0 -1" />
              <inertial pos="-0.001014 -0.013387 0.171456" quat="1.0 0.0 0.0 0.0" mass="2.212" diaginertia="0.014765 0.013374 0.003790" />
              <geom name="KC_D_301R_R_Femur_Lower_Drive_visual" pos="0 0 0" quat="1.0 0.0 0.0 0.0" material="Torso_Side_Right_material" type="mesh" mesh="KC_D_301R_R_Femur_Lower_Drive.stl" class="visual" />

              <!-- Joint: knee_angle_r (原 dof_right_knee_04) -->
              <body name="right_knee_link" pos="0.020500 -0.021000 0.212000" quat="0.5000001633974483 0.4999999999999733 -0.49999983660255165 -0.4999999999999733">
                <joint name="knee_angle_r" type="hinge" ref="0.0" class="robstride_04" range="-2.705260 0" axis="0 0 1" />
                <inertial pos="-0.024549 0.104152 0.018182" quat="1.0 0.0 0.0 0.0" mass="0.938" diaginertia="0.008239 0.001642 0.008194" />
                <geom name="KC_D_401R_R_Shin_Drive_visual" pos="0 0 0" quat="1.0 0.0 0.0 0.0" material="Torso_Side_Right_material" type="mesh" mesh="KC_D_401R_R_Shin_Drive.stl" class="visual" />
                <!-- mimic site: 右膝 -->
                <site name="right_knee_mimic" class="mimic"/>

                <!-- Joint: ankle_angle_r (原 dof_right_ankle_02) -->
                <body name="right_ankle_link" pos="-0.030000 0.290000 0.035100" quat="1.0 0.0 0.0 0.0">
                  <joint name="ankle_angle_r" type="hinge" ref="0.0" class="robstride_02" range="-0.980 1.256637" axis="0 0 1" />
                  <inertial pos="-0.017470 0.032456 -0.015742" quat="1.0 0.0 0.0 0.0" mass="0.190" diaginertia="1.135e-04 6.164e-04 5.961e-04" />
                  <geom name="KB_D_501R_R_LEG_FOOT_visual" pos="0 0 0" quat="1.0 0.0 0.0 0.0" material="Torso_Side_Right_material" type="mesh" mesh="KB_D_501R_R_LEG_FOOT.stl" class="visual" />
                  <geom name="KB_D_501R_R_LEG_FOOT_col0" type="capsule" fromto="-0.113680 0.038000 -0.029915 0.056123 0.038000 -0.029915" size="0.020000" material="collision_material" class="collision" />
                  <geom name="KB_D_501R_R_LEG_FOOT_col1" type="capsule" fromto="-0.105645 0.038000 0.001909 0.056412 0.038000 0.001909" size="0.020000" material="collision_material" class="collision" />
                  <!-- mimic site: 右腳（最重要） -->
                  <site name="right_foot_mimic" class="mimic" pos="0.075 0.0 -0.05"/>
                  <site name="right_foot" size="0.105 0.02 0.036" pos="-0.0283 0.038 -0.014" type="box" />
                </body>
              </body>
            </body>
          </body>
        </body>

        <!-- ===== 左腿 ===== -->
        <!-- Joint: hip_flexion_l (原 dof_left_hip_pitch_04) -->
        <body name="left_hip_yaw_link" pos="0.147969 0.000007 -0.284479" quat="0.5000001633974483 -0.4999999999999733 -0.49999983660255165 0.4999999999999733">
          <joint name="hip_flexion_l" type="hinge" ref="0.0" class="robstride_04" range="-1.960 2.216568" axis="0 0 1" />
          <inertial pos="-0.005644 0.004227 -0.038197" quat="1.0 0.0 0.0 0.0" mass="0.163" diaginertia="0.000270 0.000363 0.000390" />
          <geom name="KC_D_102L_L_Hip_Yoke_Drive_visual" pos="0 0 0" quat="1.0 0.0 0.0 0.0" material="Torso_Side_Right_material" type="mesh" mesh="KC_D_102L_L_Hip_Yoke_Drive.stl" class="visual" />
          <!-- mimic site: 左髖 -->
          <site name="left_hip_mimic" class="mimic" pos="0.05 0.0 0.0"/>

          <!-- Joint: hip_adduction_l (原 dof_left_hip_roll_03) -->
          <body name="left_hip_roll_link" pos="-0.028250 0.030000 -0.071000" quat="0.7071068967259818 0.0 0.7071066656470943 0.0">
            <joint name="hip_adduction_l" type="hinge" ref="0.0" class="robstride_03" range="-0.490 2.268928" axis="0 0 -1" />
            <inertial pos="0.000249 0.058017 0.025578" quat="1.0 0.0 0.0 0.0" mass="2.577" diaginertia="0.011097 0.003535 0.011585" />
            <geom name="RS03_5_visual" pos="0 0 0" quat="1.0 0.0 0.0 0.0" material="Torso_Side_Right_material" type="mesh" mesh="RS03_5.stl" class="visual" />

            <!-- Joint: hip_rotation_l (原 dof_left_hip_yaw_03) -->
            <body name="left_hip_pitch_link" pos="0 0.143000 0.024250" quat="0.7071068967259818 -0.7071066656470943 0.0 0.0">
              <joint name="hip_rotation_l" type="hinge" ref="0.0" class="robstride_03" range="-1.570796 1.570796" axis="0 0 -1" />
              <inertial pos="0.001013 -0.013386 0.171458" quat="1.0 0.0 0.0 0.0" mass="2.212" diaginertia="0.014765 0.013374 0.003790" />
              <geom name="KC_D_301L_L_Femur_Lower_Drive_visual" pos="0 0 0" quat="1.0 0.0 0.0 0.0" material="Torso_Side_Right_material" type="mesh" mesh="KC_D_301L_L_Femur_Lower_Drive.stl" class="visual" />

              <!-- Joint: knee_angle_l (原 dof_left_knee_04) -->
              <body name="left_knee_link" pos="-0.020500 -0.021000 0.212000" quat="0.5000001633974483 -0.4999999999999733 0.49999983660255165 -0.4999999999999733">
                <joint name="knee_angle_l" type="hinge" ref="0.0" class="robstride_04" range="0 2.705260" axis="0 0 1" />
                <inertial pos="-0.024550 -0.104154 0.018183" quat="1.0 0.0 0.0 0.0" mass="0.938" diaginertia="0.008239 0.001642 0.008194" />
                <geom name="KC_D_401L_L_Shin_Drive_visual" pos="0 0 0" quat="1.0 0.0 0.0 0.0" material="Torso_Side_Right_material" type="mesh" mesh="KC_D_401L_L_Shin_Drive.stl" class="visual" />
                <!-- mimic site: 左膝 -->
                <site name="left_knee_mimic" class="mimic"/>

                <!-- Joint: ankle_angle_l (原 dof_left_ankle_02) -->
                <body name="left_ankle_link" pos="-0.030000 -0.290000 0.035100" quat="-1.7320510330969933e-07 -0.999999999999985 -0.0 0.0">
                  <joint name="ankle_angle_l" type="hinge" ref="0.0" class="robstride_02" range="-1.256637 0.470" axis="0 0 -1" />
                  <inertial pos="-0.017470 0.032456 0.015742" quat="1.0 0.0 0.0 0.0" mass="0.190" diaginertia="1.135e-04 6.164e-04 5.961e-04" />
                  <geom name="KB_D_501L_L_LEG_FOOT_visual" pos="0 0 0" quat="1.0 0.0 0.0 0.0" material="Torso_Side_Right_material" type="mesh" mesh="KB_D_501L_L_LEG_FOOT.stl" class="visual" />
                  <geom name="KB_D_501L_L_LEG_FOOT_col0" type="capsule" fromto="-0.100503 0.037962 -0.001909 0.056400 0.037962 -0.001909" size="0.020000" material="collision_material" class="collision" />
                  <geom name="KB_D_501L_L_LEG_FOOT_col1" type="capsule" fromto="-0.113680 0.037962 0.029830 0.055824 0.037962 0.029830" size="0.020000" material="collision_material" class="collision" />
                  <!-- mimic site: 左腳（最重要） -->
                  <site name="left_foot_mimic" class="mimic" pos="0.075 0.0 -0.05"/>
                  <site name="left_foot" size="0.105 0.02 0.036" pos="-0.0283 0.038 0.014" type="box" />
                </body>
              </body>
            </body>
          </body>
        </body>

        <!-- 靜態手臂（無關節，僅保留質量） -->
        <body name="arm_L" pos="0.02 0 0" quat="0 0 0 1">
          <inertial pos="0.120 -0.003 -0.146" mass="1.4" diaginertia="0.014 0.021 0.007" />
          <geom name="arm_L_visual" type="mesh" mesh="arm_left" pos="-0.347 0.156 -0.486" material="default_material" contype="0" conaffinity="0" group="2" />
        </body>
        <body name="arm_R" pos="0.02 0 0" quat="1 0 0 0">
          <inertial pos="0.266 0.003 -0.146" mass="1.4" diaginertia="0.014 0.021 0.007" />
          <geom name="arm_R_visual" type="mesh" mesh="arm_right" pos="-0.201 -0.156 -0.486" material="default_material" contype="0" conaffinity="0" group="2" />
        </body>

      </body>

      <site name="base_site" pos="0 0 0" quat="1 0 0 0" size="0.001" />
      <camera name="front_camera" mode="track" fovy="90.0" quat="4.329780281177467e-17 4.329780281177466e-17 0.7071067811865475 0.7071067811865476" pos="0.0 2.0 0.5" />
    </body>
  </worldbody>

  <!-- 10 個腿部 actuator（使用 H1 對應名稱） -->
  <actuator>
    <motor name="hip_flexion_r_actuator"   joint="hip_flexion_r"   class="robstride_04" />
    <motor name="hip_adduction_r_actuator" joint="hip_adduction_r" class="robstride_03" />
    <motor name="hip_rotation_r_actuator"  joint="hip_rotation_r"  class="robstride_03" />
    <motor name="knee_angle_r_actuator"    joint="knee_angle_r"    class="robstride_04" />
    <motor name="ankle_angle_r_actuator"   joint="ankle_angle_r"   class="robstride_02" />
    <motor name="hip_flexion_l_actuator"   joint="hip_flexion_l"   class="robstride_04" />
    <motor name="hip_adduction_l_actuator" joint="hip_adduction_l" class="robstride_03" />
    <motor name="hip_rotation_l_actuator"  joint="hip_rotation_l"  class="robstride_03" />
    <motor name="knee_angle_l_actuator"    joint="knee_angle_l"    class="robstride_04" />
    <motor name="ankle_angle_l_actuator"   joint="ankle_angle_l"   class="robstride_02" />
  </actuator>

  <sensor>
    <framepos name="base_site_pos" objtype="site" objname="base_site" />
    <framequat name="base_site_quat" objtype="site" objname="base_site" />
    <framelinvel name="base_site_linvel" objtype="site" objname="base_site" />
    <frameangvel name="base_site_angvel" objtype="site" objname="base_site" />
    <accelerometer name="imu_acc" site="imu_site" noise="0.01" />
    <gyro name="imu_gyro" site="imu_site" noise="0.01" />
    <jointpos name="hip_flexion_r_pos"   joint="hip_flexion_r" />
    <jointpos name="hip_adduction_r_pos" joint="hip_adduction_r" />
    <jointpos name="hip_rotation_r_pos"  joint="hip_rotation_r" />
    <jointpos name="knee_angle_r_pos"    joint="knee_angle_r" />
    <jointpos name="ankle_angle_r_pos"   joint="ankle_angle_r" />
    <jointpos name="hip_flexion_l_pos"   joint="hip_flexion_l" />
    <jointpos name="hip_adduction_l_pos" joint="hip_adduction_l" />
    <jointpos name="hip_rotation_l_pos"  joint="hip_rotation_l" />
    <jointpos name="knee_angle_l_pos"    joint="knee_angle_l" />
    <jointpos name="ankle_angle_l_pos"   joint="ankle_angle_l" />
    <jointvel name="hip_flexion_r_vel"   joint="hip_flexion_r" />
    <jointvel name="hip_adduction_r_vel" joint="hip_adduction_r" />
    <jointvel name="hip_rotation_r_vel"  joint="hip_rotation_r" />
    <jointvel name="knee_angle_r_vel"    joint="knee_angle_r" />
    <jointvel name="ankle_angle_r_vel"   joint="ankle_angle_r" />
    <jointvel name="hip_flexion_l_vel"   joint="hip_flexion_l" />
    <jointvel name="hip_adduction_l_vel" joint="hip_adduction_l" />
    <jointvel name="hip_rotation_l_vel"  joint="hip_rotation_l" />
    <jointvel name="knee_angle_l_vel"    joint="knee_angle_l" />
    <jointvel name="ankle_angle_l_vel"   joint="ankle_angle_l" />
    <force name="right_foot_force" site="right_foot" />
    <force name="left_foot_force"  site="left_foot" />
    <touch name="right_foot_touch" site="right_foot" />
    <touch name="left_foot_touch"  site="left_foot" />
  </sensor>

</mujoco>
